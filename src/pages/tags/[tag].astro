---
import TagPage from "../../components/TagPage.astro";
import { getAllTagsByLocale } from "../../lib/posts";
import { tagSlug } from "../../lib/tags";

export async function getStaticPaths() {
  const tags = await getAllTagsByLocale("en");
  return [...tags.entries()].map(([tag, posts]) => ({
    params: { tag: tagSlug(tag) },
    props: { tag, posts },
  }));
}

const { tag, posts } = Astro.props;
---

<TagPage locale="en" tag={tag} posts={posts} />
