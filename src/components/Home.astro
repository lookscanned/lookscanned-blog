---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "./PostList.astro";
import Pagination from "./Pagination.astro";
import { getLocale } from "../i18n";
import { getPostsByLocale } from "../lib/posts";
import { paginateItems, PAGE_SIZE } from "../lib/paginate";

interface Props {
  locale: string;
  page?: number;
}

const { locale, page = 1 } = Astro.props;
const meta = getLocale(locale);
const all = await getPostsByLocale(locale);
const pages = paginateItems(all, PAGE_SIZE);
const current = pages[Math.max(0, Math.min(page - 1, pages.length - 1))];

const title = page > 1
  ? `${meta.data.title} · ${page}/${current.total}`
  : meta.data.title;

const sinceYear = 2025;
const currentYear = new Date().getFullYear();
const dateline = sinceYear === currentYear
  ? `Est. ${sinceYear}`
  : `${sinceYear}–${currentYear}`;
---

<BaseLayout title={title} description={meta.data.description} locale={locale}>
  <main class="mx-auto max-w-3xl px-6">
    {page === 1 && (
      <section class="pt-10 pb-12 sm:pt-16">
        <p class="font-ui text-[11px] uppercase tracking-[0.18em] text-(--color-ink-faint)">
          {dateline} · Vol. {currentYear - sinceYear + 1}
        </p>
        <h1 class="font-display mt-4 text-[2.75rem] font-medium italic leading-[1.05] tracking-tight text-balance text-(--color-ink) sm:text-[3.5rem] dark:text-(--color-paper-fg-2)">
          {meta.data.homeTitle}
        </h1>
        <p class="font-ui mt-6 max-w-xl text-[15px] leading-relaxed text-(--color-ink-mute) dark:text-(--color-ink-faint)">
          {meta.data.description}
        </p>
      </section>
    )}
    {page > 1 && (
      <section class="pt-10 pb-8">
        <p class="font-ui text-[11px] uppercase tracking-[0.18em] text-(--color-ink-faint)">
          Page {page} of {current.total}
        </p>
      </section>
    )}
    <div class="border-t border-double border-(--color-rule) dark:border-(--color-rule-dark)">
      <PostList posts={current.items} />
    </div>
    <Pagination locale={locale} current={current.page} total={current.total} basePath="" />
  </main>
</BaseLayout>
