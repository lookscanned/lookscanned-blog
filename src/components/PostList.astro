---
import PostCard from "./PostCard.astro";
import type { PostMeta } from "../lib/posts";

interface Props {
  posts: PostMeta[];
}

const { posts } = Astro.props;
---

<section class="divide-y divide-(--color-rule) dark:divide-(--color-rule-dark)">
  {posts.map((post) => <PostCard post={post} />)}
</section>
