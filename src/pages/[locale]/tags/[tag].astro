---
import TagPage from "../../../components/TagPage.astro";
import { getAllTagsByLocale } from "../../../lib/posts";
import { tagSlug } from "../../../lib/tags";
import { LOCALES, DEFAULT_LOCALE } from "../../../i18n/locales.config.mjs";

export async function getStaticPaths() {
  const out = [];
  for (const l of LOCALES) {
    if (l.code === DEFAULT_LOCALE) continue;
    const tags = await getAllTagsByLocale(l.code);
    for (const [tag, posts] of tags.entries()) {
      out.push({
        params: { locale: l.code, tag: tagSlug(tag) },
        props: { locale: l.code, tag, posts },
      });
    }
  }
  return out;
}

const { locale, tag, posts } = Astro.props;
---

<TagPage locale={locale} tag={tag} posts={posts} />
