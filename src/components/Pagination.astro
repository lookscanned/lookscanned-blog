---
import { getLocale } from "../i18n";

interface Props {
  locale: string;
  current: number;
  total: number;
  /** Path prefix without trailing slash, e.g. "" for home, "/posts" for section. */
  basePath: string;
}

const { locale, current, total, basePath } = Astro.props;
if (total <= 1) return null;

const meta = getLocale(locale);
const localeRoot = locale === "en" ? "" : `/${locale}`;
const indexUrl = `${localeRoot}${basePath}/`.replace(/^\/\//, "/");

function url(page: number): string {
  if (page === 1) return basePath === "" ? `${localeRoot || "/"}` + (localeRoot ? "/" : "") : indexUrl;
  return `${localeRoot}${basePath}/page/${page}/`;
}

const prev = current > 1 ? url(current - 1) : null;
const next = current < total ? url(current + 1) : null;
---

<nav class="mt-16 grid grid-cols-2 gap-6 border-t border-(--color-rule) pt-6 dark:border-(--color-rule-dark)">
  <div>
    {prev && (
      <a href={prev} class="block transition hover:text-(--color-accent-600) dark:hover:text-(--color-accent-400-dark)">
        <span class="font-ui text-[10px] uppercase tracking-[0.18em] text-(--color-ink-faint)">← Older</span>
        <span class="font-display block mt-1 italic text-(--color-ink-soft) dark:text-(--color-paper-fg)">{meta.ui.prev_page}</span>
      </a>
    )}
  </div>
  <div class="text-right">
    {next && (
      <a href={next} class="block transition hover:text-(--color-accent-600) dark:hover:text-(--color-accent-400-dark)">
        <span class="font-ui text-[10px] uppercase tracking-[0.18em] text-(--color-ink-faint)">Newer →</span>
        <span class="font-display block mt-1 italic text-(--color-ink-soft) dark:text-(--color-paper-fg)">{meta.ui.next_page}</span>
      </a>
    )}
  </div>
</nav>
