---
import type { PostMeta } from "../lib/posts";
import { localizedPath } from "../i18n";
import { formatDate } from "../lib/date";

interface Props {
  post: PostMeta;
}

const { post } = Astro.props;
const href = localizedPath(post.locale, `posts/${post.slug}`);
---

<article class="group">
  <a href={href} class="block py-6 transition">
    <h2
      class="text-2xl font-medium tracking-tight text-zinc-900 transition group-hover:text-accent-600 dark:text-zinc-50 dark:group-hover:text-accent-400"
      style={`view-transition-name: post-title-${post.slug}`}
    >
      {post.entry.data.title}
    </h2>
    <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-500">
      <time datetime={post.entry.data.date.toISOString()}>
        {formatDate(post.locale, post.entry.data.date)}
      </time>
    </p>
    {post.entry.data.summary && (
      <p class="mt-3 line-clamp-3 text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
        {post.entry.data.summary}
      </p>
    )}
  </a>
</article>
