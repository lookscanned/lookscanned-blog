---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

// Giscus's own language list (https://github.com/giscus/giscus/blob/main/lib/i18n.ts).
// Fall back to English for locales it doesn't ship.
const GISCUS_LANG_MAP: Record<string, string> = {
  ar: "ar", be: "be", bg: "bg", ca: "ca", cs: "cs", da: "da", de: "de",
  el: "gr", en: "en", eo: "eo", es: "es", eu: "eu", fa: "fa", fil: "en",
  fr: "fr", he: "he", hu: "hu", id: "id", it: "it", ja: "ja", km: "kh",
  ko: "ko", nl: "nl", pl: "pl", pt: "pt", ro: "ro", ru: "ru", th: "th",
  tr: "tr", uk: "uk", uz: "uz", vi: "vi",
  zh: "zh-CN", "zh-tw": "zh-TW", "zh-hk": "zh-HK",
};
const giscusLang = GISCUS_LANG_MAP[locale] ?? "en";
---

<section class="mt-16">
  {/* Inline script tag — Giscus uses document.currentScript.parentElement
      to know where to inject its <iframe>. Setting up the script this
      way (rather than dynamically appending it from another script) is
      what guarantees the iframe lands inside this <section> at full
      width. The theme is initialised to follow OS preference and then
      synced to our app's actual state below via postMessage. */}
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo="lookscanned/lookscanned-blog"
    data-repo-id="R_kgDONrCyPw"
    data-category="Announcements"
    data-category-id="DIC_kwDONrCyP84CmK9C"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-theme="preferred_color_scheme"
    data-lang={giscusLang}
    crossorigin="anonymous"
    async
  ></script>
</section>

<script is:inline>
  /*
   * Theme sync. Two paths into the iframe:
   *   1. On first 'discussion' message from giscus.app, immediately
   *      override the OS-default theme with our app's current state
   *      (handles users whose manual choice differs from OS).
   *   2. On subsequent `themechange` CustomEvent (dispatched by
   *      ThemeToggle), propagate to the iframe too.
   */
  (() => {
    const sendTheme = (dark) => {
      const frame = document.querySelector("iframe.giscus-frame");
      if (!frame || !frame.contentWindow) return;
      frame.contentWindow.postMessage(
        { giscus: { setConfig: { theme: dark ? "dark" : "light" } } },
        "https://giscus.app",
      );
    };
    const currentDark = () =>
      document.documentElement.classList.contains("dark");

    window.addEventListener("message", (event) => {
      if (event.origin !== "https://giscus.app") return;
      const data = event.data;
      if (data && data.giscus && data.giscus.discussion) {
        sendTheme(currentDark());
      }
    });

    document.addEventListener("themechange", (event) => {
      sendTheme(Boolean(event.detail && event.detail.dark));
    });
  })();
</script>
