---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "./PostList.astro";
import Pagination from "./Pagination.astro";
import { getLocale } from "../i18n";
import { getPostsByLocale } from "../lib/posts";
import { paginateItems, PAGE_SIZE } from "../lib/paginate";

interface Props {
  locale: string;
  page?: number;
}

const { locale, page = 1 } = Astro.props;
const meta = getLocale(locale);
const all = await getPostsByLocale(locale);
const pages = paginateItems(all, PAGE_SIZE);
const current = pages[Math.max(0, Math.min(page - 1, pages.length - 1))];

const heading = "Posts";
const title = page > 1
  ? `${heading} · ${page}/${current.total} · ${meta.data.title}`
  : `${heading} · ${meta.data.title}`;
---

<BaseLayout title={title} description={meta.data.description} locale={locale} pageKey="posts">
  <main class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="text-2xl font-medium tracking-tight text-zinc-950 dark:text-zinc-50">{heading}</h1>
    <div class="mt-8">
      <PostList posts={current.items} />
    </div>
    <Pagination locale={locale} current={current.page} total={current.total} basePath="/posts" />
  </main>
</BaseLayout>
