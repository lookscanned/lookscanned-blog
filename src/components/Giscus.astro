---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

// Map our locale codes to Giscus's lang list. Fallback to "en".
const GISCUS_LANG_MAP: Record<string, string> = {
  ar: "ar", be: "be", bg: "bg", ca: "ca", cs: "cs", da: "da", de: "de",
  el: "gr", en: "en", eo: "eo", es: "es", eu: "eu", fa: "fa", fil: "en",
  fr: "fr", he: "he", hu: "hu", id: "id", it: "it", ja: "ja", km: "kh",
  ko: "ko", nl: "nl", pl: "pl", pt: "pt", ro: "ro", ru: "ru", th: "th",
  tr: "tr", uk: "uk", uz: "uz", vi: "vi",
  zh: "zh-CN", "zh-tw": "zh-TW", "zh-hk": "zh-HK",
};
const giscusLang = GISCUS_LANG_MAP[locale] ?? "en";
---

<section class="mt-16" id="giscus-section"></section>

<script is:inline define:vars={{ giscusLang }}>
  (() => {
    const section = document.getElementById("giscus-section");
    if (!section) return;

    // Read current theme from html.dark — the BaseLayout pre-paint
    // script has already applied the correct class by the time this
    // runs, so this is the source of truth at first paint.
    const initialDark = document.documentElement.classList.contains("dark");

    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.async = true;
    script.crossOrigin = "anonymous";
    Object.assign(script.dataset, {
      repo: "lookscanned/lookscanned-blog",
      repoId: "R_kgDONrCyPw",
      category: "Announcements",
      categoryId: "DIC_kwDONrCyP84CmK9C",
      mapping: "pathname",
      strict: "0",
      reactionsEnabled: "1",
      emitMetadata: "0",
      theme: initialDark ? "dark" : "light",
      lang: giscusLang,
    });
    section.appendChild(script);

    // Keep the embedded iframe in sync when the user toggles dark mode
    // via ThemeToggle (which dispatches a `themechange` CustomEvent).
    const updateTheme = (dark) => {
      const frame = document.querySelector("iframe.giscus-frame");
      if (!frame || !frame.contentWindow) return;
      frame.contentWindow.postMessage(
        { giscus: { setConfig: { theme: dark ? "dark" : "light" } } },
        "https://giscus.app",
      );
    };
    document.addEventListener("themechange", (event) => {
      updateTheme(Boolean(event.detail && event.detail.dark));
    });
  })();
</script>
