---
import { getLocale, localizedPath } from "../i18n";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const meta = getLocale(locale);
const year = new Date().getFullYear();
const rssUrl = locale === "en" ? "/rss.xml" : `/${locale}/rss.xml`;

// Resolve translated labels from the per-locale menu data. Falls back to
// English if the entry is missing for some reason (unlikely — all 32
// locales ship the full menu).
function menuLabel(url: string, fallback: string): string {
  return meta.data.menu.find((m) => m.url === url)?.name ?? fallback;
}

const browseLinks = [
  { href: localizedPath(locale, "archives"), label: menuLabel("archives", "Archive") },
  { href: localizedPath(locale, "tags"), label: menuLabel("tags", "Tags") },
  { href: localizedPath(locale, "search"), label: menuLabel("search", "Search") },
];

const connectLinks = [
  { href: "https://lookscanned.io", label: "Look Scanned", external: true },
  { href: "https://github.com/lookscanned", label: "GitHub", external: true },
  { href: rssUrl, label: "RSS", external: false },
];
---

<footer class="mt-24 border-t border-zinc-200/60 dark:border-zinc-800/60">
  <div class="mx-auto max-w-5xl px-6 py-14">
    <div class="grid gap-10 md:grid-cols-[2fr_1fr_1fr]">
      <div>
        <p class="text-base font-medium tracking-tight text-zinc-900 dark:text-zinc-50">
          {meta.data.title}
        </p>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
          {meta.data.description}
        </p>
      </div>

      <div>
        <p class="mb-4 text-xs uppercase tracking-[0.18em] text-zinc-400 dark:text-zinc-600">
          {meta.ui.browse_label}
        </p>
        <ul class="flex flex-col gap-3 text-sm">
          {browseLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-zinc-600 underline-offset-[3px] transition hover:underline dark:text-zinc-400"
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="mb-4 text-xs uppercase tracking-[0.18em] text-zinc-400 dark:text-zinc-600">
          {meta.ui.connect_label}
        </p>
        <ul class="flex flex-col gap-3 text-sm">
          {connectLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-zinc-600 underline-offset-[3px] transition hover:underline dark:text-zinc-400"
                {...link.external ? { target: "_blank", rel: "noopener noreferrer" } : {}}
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="mt-12 border-t border-zinc-200/60 pt-6 text-xs text-zinc-500 dark:border-zinc-800/60 dark:text-zinc-400">
      &copy; {year} {meta.data.title}
    </p>
  </div>
</footer>
