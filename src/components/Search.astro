---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocale } from "../i18n";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const meta = getLocale(locale);
const menuEntry = meta.menu.find((m) => m.url === "search");
const heading = menuEntry?.name ?? "Search";
---

<BaseLayout title={`${heading} · ${meta.title}`} description={meta.description} locale={locale} pageKey="search">
  <div class="mx-auto max-w-5xl px-6 pt-12 pb-12 sm:pt-16">
    <h1 class="text-3xl font-medium leading-tight tracking-tight text-zinc-900 sm:text-4xl dark:text-zinc-50">
      {heading}
    </h1>
    <div id="search" class="mt-10" data-pagefind-ui></div>
  </div>
</BaseLayout>

<link rel="stylesheet" href="/_pagefind/pagefind-ui.css" />
<script is:inline src="/_pagefind/pagefind-ui.js"></script>
<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    if (typeof PagefindUI === "undefined") {
      const el = document.getElementById("search");
      if (el) el.innerHTML = '<p class="text-sm">Search index is generated at build time.</p>';
      return;
    }
    new PagefindUI({
      element: "#search",
      showSubResults: true,
      resetStyles: false,
      ranking: { termFrequency: 0.5, pageLength: 0.5 },
      pageSize: 10,
    });
  });
</script>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-primary: var(--color-accent-600);
    --pagefind-ui-text: currentColor;
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--color-zinc-200);
    --pagefind-ui-tag: var(--color-zinc-100);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: inherit;
  }
  html.dark .pagefind-ui {
    --pagefind-ui-border: var(--color-zinc-800);
    --pagefind-ui-tag: var(--color-zinc-900);
  }
  .pagefind-ui__search-input { font-size: 0.95rem !important; background: transparent !important; }
  .pagefind-ui__result { padding: 1rem 0 !important; }
</style>
