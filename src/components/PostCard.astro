---
import type { PostMeta } from "../lib/posts";
import { localizedPath } from "../i18n";

interface Props {
  post: PostMeta;
}

const { post } = Astro.props;
const href = localizedPath(post.locale, `posts/${post.slug}`);
const dateStr = post.entry.data.date.toISOString().slice(0, 10);
---

<article class="group">
  <a href={href} class="block py-5 transition">
    <h2 class="text-lg font-medium tracking-tight text-zinc-900 transition group-hover:text-accent-600 dark:text-zinc-100 dark:group-hover:text-accent-500">
      {post.entry.data.title}
    </h2>
    <p class="mt-1 text-xs text-zinc-500">
      <time datetime={post.entry.data.date.toISOString()}>{dateStr}</time>
    </p>
    {post.entry.data.summary && (
      <p class="mt-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400 line-clamp-3">
        {post.entry.data.summary}
      </p>
    )}
  </a>
</article>
