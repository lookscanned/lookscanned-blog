---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 · Look Scanned Blog" locale="en">
  <main class="mx-auto max-w-3xl px-6 py-24 text-center sm:py-32">
    <h1 class="font-display text-6xl font-medium leading-none tracking-tight text-zinc-900 sm:text-7xl dark:text-zinc-50">
      404
    </h1>
    <p class="font-ui mt-6 text-zinc-600 dark:text-zinc-400">
      Page not found.
    </p>
    <a
      href="/"
      class="font-ui mt-8 inline-block text-sm text-accent-600 underline-offset-[3px] hover:underline dark:text-accent-400"
    >Back to home →</a>
  </main>
</BaseLayout>
