---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 · Look Scanned Blog" locale="en">
  <main class="mx-auto max-w-2xl px-6 py-32 text-center">
    <h1 class="text-5xl font-medium tracking-tight">404</h1>
    <p class="mt-4 text-zinc-600 dark:text-zinc-400">
      This page could not be found.
    </p>
    <a
      href="/"
      class="mt-8 inline-block text-sm text-accent-600 underline-offset-4 hover:underline dark:text-accent-500"
    >Go home →</a>
  </main>
</BaseLayout>
