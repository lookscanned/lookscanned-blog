---
import { getLocale } from "../i18n";

interface Props {
  locale: string;
  current: number;
  total: number;
  basePath: string;
}

const { locale, current, total, basePath } = Astro.props;
if (total <= 1) return null;

const meta = getLocale(locale);
const localeRoot = locale === "en" ? "" : `/${locale}`;
const indexUrl = `${localeRoot}${basePath}/`.replace(/^\/\//, "/");

function url(page: number): string {
  if (page === 1) {
    if (basePath === "") return localeRoot ? `${localeRoot}/` : "/";
    return indexUrl;
  }
  return `${localeRoot}${basePath}/page/${page}/`;
}

const prev = current > 1 ? url(current - 1) : null;
const next = current < total ? url(current + 1) : null;
---

<nav class="mt-16 grid grid-cols-2 gap-6 border-t border-zinc-200 pt-6 text-sm dark:border-zinc-800">
  <div>
    {prev && (
      <a href={prev} class="text-zinc-600 transition hover:text-accent-600 dark:text-zinc-400 dark:hover:text-accent-400">
        ← {meta.ui.prev_page}
      </a>
    )}
  </div>
  <div class="text-right">
    {next && (
      <a href={next} class="text-zinc-600 transition hover:text-accent-600 dark:text-zinc-400 dark:hover:text-accent-400">
        {meta.ui.next_page} →
      </a>
    )}
  </div>
</nav>
