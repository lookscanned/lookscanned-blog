---
import { localizedPath } from "../i18n";
import { tagSlug } from "../lib/tags";

interface Props {
  locale: string;
  tags: string[];
}

const { locale, tags } = Astro.props;
---

{tags.length > 0 && (
  <ul class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <li>
        <a
          href={localizedPath(locale, `tags/${tagSlug(tag)}`)}
          class="inline-block rounded px-2 py-0.5 text-xs text-zinc-600 ring-1 ring-zinc-200 transition hover:text-zinc-900 hover:ring-zinc-300 dark:text-zinc-400 dark:ring-zinc-800 dark:hover:text-zinc-100 dark:hover:ring-zinc-700"
        >
          {tag}
        </a>
      </li>
    ))}
  </ul>
)}
