---
import { formatReadingTime } from "../i18n";
import { formatDate } from "../lib/date";
import readingTime from "reading-time";

interface Props {
  locale: string;
  date: Date;
  body: string;
}

const { locale, date, body } = Astro.props;
const rt = readingTime(body);
const minutes = Math.max(1, Math.round(rt.minutes));
---

<div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-zinc-500 dark:text-zinc-400">
  <time datetime={date.toISOString()}>{formatDate(locale, date)}</time>
  <span aria-hidden="true">·</span>
  <span>{formatReadingTime(locale, minutes)}</span>
</div>
