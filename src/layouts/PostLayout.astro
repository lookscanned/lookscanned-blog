---
import BaseLayout from "./BaseLayout.astro";
import PostMeta from "../components/PostMeta.astro";
import Giscus from "../components/Giscus.astro";
import { getLocale, localizedPath } from "../i18n";
import { getPostsByLocale, getTranslations, type PostMeta as PostMetaType } from "../lib/posts";

interface Props {
  post: PostMetaType;
  body: string;
}

const { post, body } = Astro.props;
const meta = getLocale(post.locale);

const translations = await getTranslations(post.dirSlug);
const alternates = translations.map((t) => ({ locale: t.locale, slug: t.slug }));

// Adjacent posts (newer / older) in the same locale.
const samelocale = await getPostsByLocale(post.locale);
const idx = samelocale.findIndex((p) => p.dirSlug === post.dirSlug);
const newer = idx > 0 ? samelocale[idx - 1] : null;
const older = idx >= 0 && idx < samelocale.length - 1 ? samelocale[idx + 1] : null;

const title = `${post.entry.data.title} · ${meta.data.title}`;
const description = post.entry.data.description ?? post.entry.data.summary ?? "";
---

<BaseLayout title={title} description={description} locale={post.locale} alternates={alternates}>
  <article class="mx-auto max-w-2xl px-6 py-12" data-pagefind-body>
    <header class="mb-10">
      <h1 class="text-3xl font-medium tracking-tight text-balance">
        {post.entry.data.title}
      </h1>
      <div class="mt-4">
        <PostMeta
          locale={post.locale}
          date={post.entry.data.date}
          tags={post.entry.data.tags}
          body={body}
        />
      </div>
    </header>
    <div class="prose prose-zinc max-w-none dark:prose-invert
      prose-headings:font-medium prose-headings:tracking-tight
      prose-a:text-accent-600 prose-a:no-underline hover:prose-a:underline dark:prose-a:text-accent-500
      prose-code:rounded prose-code:bg-zinc-100 prose-code:px-1 prose-code:py-0.5 prose-code:font-normal prose-code:text-zinc-900
      dark:prose-code:bg-zinc-800 dark:prose-code:text-zinc-100
      prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-zinc-950 prose-pre:text-zinc-100 prose-pre:border prose-pre:border-zinc-800
      prose-img:rounded-md prose-img:border prose-img:border-zinc-200 dark:prose-img:border-zinc-800">
      <slot />
    </div>

    {translations.length > 1 && (
      <section class="mt-12 border-t border-zinc-200 pt-6 text-sm dark:border-zinc-800">
        <p class="text-zinc-500 dark:text-zinc-400">
          <span class="font-medium text-zinc-700 dark:text-zinc-300">{meta.ui.translations}:</span>
          {" "}
          {translations
            .filter((t) => t.locale !== post.locale)
            .map((t, i, arr) => (
              <>
                <a
                  href={localizedPath(t.locale, `posts/${t.slug}`)}
                  lang={t.locale}
                  class="text-zinc-600 underline-offset-2 hover:text-zinc-900 hover:underline dark:text-zinc-400 dark:hover:text-zinc-100"
                >
                  {(getLocale(t.locale).data.languageName)}
                </a>
                {i < arr.length - 1 && <span>, </span>}
              </>
            ))}
        </p>
      </section>
    )}

    {(newer || older) && (
      <nav class="mt-10 flex justify-between gap-6 border-t border-zinc-200 pt-6 text-sm dark:border-zinc-800">
        <div class="flex-1">
          {older && (
            <a href={localizedPath(older.locale, `posts/${older.slug}`)} class="block transition hover:text-accent-600 dark:hover:text-accent-500">
              <div class="text-xs text-zinc-500">← {meta.ui.prev_page}</div>
              <div class="mt-1 line-clamp-1">{older.entry.data.title}</div>
            </a>
          )}
        </div>
        <div class="flex-1 text-right">
          {newer && (
            <a href={localizedPath(newer.locale, `posts/${newer.slug}`)} class="block transition hover:text-accent-600 dark:hover:text-accent-500">
              <div class="text-xs text-zinc-500">{meta.ui.next_page} →</div>
              <div class="mt-1 line-clamp-1">{newer.entry.data.title}</div>
            </a>
          )}
        </div>
      </nav>
    )}

    <Giscus locale={post.locale} />
  </article>
</BaseLayout>
