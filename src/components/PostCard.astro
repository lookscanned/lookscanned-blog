---
import type { PostMeta } from "../lib/posts";
import { localizedPath, formatReadingTime } from "../i18n";
import { formatDate } from "../lib/date";
import readingTime from "reading-time";

interface Props {
  post: PostMeta;
}

const { post } = Astro.props;
const href = localizedPath(post.locale, `posts/${post.slug}`);

const rt = readingTime(post.entry.body ?? "");
const minutes = Math.max(1, Math.round(rt.minutes));
---

<article class="group">
  <a href={href} class="block py-6">
    <h2
      class="text-2xl font-medium tracking-tight text-zinc-900 underline-offset-[3px] transition group-hover:underline dark:text-zinc-50"
      style={`view-transition-name: post-title-${post.slug}`}
    >
      {post.entry.data.title}
    </h2>
    {post.entry.data.summary && (
      <p class="mt-3 line-clamp-3 text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
        {post.entry.data.summary}
      </p>
    )}
    <div class="mt-3 flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-500">
      <time datetime={post.entry.data.date.toISOString()}>
        {formatDate(post.locale, post.entry.data.date)}
      </time>
      <span aria-hidden="true">·</span>
      <span>{formatReadingTime(post.locale, minutes)}</span>
    </div>
  </a>
</article>
