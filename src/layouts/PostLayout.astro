---
import BaseLayout from "./BaseLayout.astro";
import Giscus from "../components/Giscus.astro";
import { getLocale, formatReadingTime, localizedPath } from "../i18n";
import { formatDate } from "../lib/date";
import { tagSlug } from "../lib/tags";
import { getPostsByLocale, getTranslations, type PostMeta as PostMetaType } from "../lib/posts";
import readingTime from "reading-time";

interface Props {
  post: PostMetaType;
  body: string;
}

const { post, body } = Astro.props;
const meta = getLocale(post.locale);

const translations = await getTranslations(post.dirSlug);
const alternates = translations.map((t) => ({
  locale: t.locale,
  path: `posts/${t.slug}`,
}));

const samelocale = await getPostsByLocale(post.locale);
const idx = samelocale.findIndex((p) => p.dirSlug === post.dirSlug);
const newer = idx > 0 ? samelocale[idx - 1] : null;
const older = idx >= 0 && idx < samelocale.length - 1 ? samelocale[idx + 1] : null;

const title = `${post.entry.data.title} · ${meta.data.title}`;
const description = post.entry.data.description ?? post.entry.data.summary ?? "";

const rt = readingTime(body);
const minutes = Math.max(1, Math.round(rt.minutes));

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.entry.data.title,
  description,
  datePublished: post.entry.data.date.toISOString(),
  inLanguage: meta.hreflang,
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  keywords: post.entry.data.tags,
  publisher: { "@type": "Organization", name: "Look Scanned", url: "https://lookscanned.io" },
  author: { "@type": "Organization", name: "Look Scanned" },
};

const day = String(post.entry.data.date.getDate()).padStart(2, "0");
const monthShort = post.entry.data.date
  .toLocaleDateString("en-US", { month: "short" })
  .toUpperCase();
const year = post.entry.data.date.getFullYear();
---

<BaseLayout
  title={title}
  description={description}
  locale={post.locale}
  alternates={alternates}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl px-6 py-12" data-pagefind-body>
    <header class="mb-12">
      <p class="font-ui flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-(--color-ink-faint)">
        <span class="font-mono tabular-nums">{day} {monthShort} {year}</span>
        <span aria-hidden="true">·</span>
        <span>{formatReadingTime(post.locale, minutes)}</span>
      </p>
      <h1 class="font-display mt-6 text-[2.5rem] font-medium leading-[1.1] tracking-tight text-balance text-(--color-ink) sm:text-[3rem] dark:text-(--color-paper-fg-2)">
        {post.entry.data.title}
      </h1>
      {post.entry.data.summary && (
        <p class="font-display mt-6 text-[1.25rem] italic leading-relaxed text-(--color-ink-soft) text-pretty dark:text-(--color-paper-fg)">
          {post.entry.data.summary}
        </p>
      )}
      <p class="font-ui mt-6 text-xs text-(--color-ink-faint)" lang={post.locale}>
        <time datetime={post.entry.data.date.toISOString()}>
          {formatDate(post.locale, post.entry.data.date)}
        </time>
      </p>
    </header>

    <div class="rule-ornament pb-10 text-xs">* * *</div>

    <div class:list={[
      "editorial-prose prose prose-lg max-w-none",
      "[--tw-prose-body:var(--color-ink-soft)] dark:[--tw-prose-body:var(--color-paper-fg)]",
      "[--tw-prose-headings:var(--color-ink)] dark:[--tw-prose-headings:var(--color-paper-fg-2)]",
      "[--tw-prose-bold:var(--color-ink)] dark:[--tw-prose-bold:var(--color-paper-fg-2)]",
      "[--tw-prose-links:var(--color-accent-600)] dark:[--tw-prose-links:var(--color-accent-400-dark)]",
      "[--tw-prose-quotes:var(--color-ink-soft)] dark:[--tw-prose-quotes:var(--color-paper-fg)]",
      "[--tw-prose-quote-borders:var(--color-accent-600)]",
      "[--tw-prose-hr:var(--color-rule)] dark:[--tw-prose-hr:var(--color-rule-dark)]",
      "[--tw-prose-bullets:var(--color-ink-faint)]",
      "[--tw-prose-counters:var(--color-ink-faint)]",
      "[--tw-prose-captions:var(--color-ink-mute)] dark:[--tw-prose-captions:var(--color-ink-faint)]",
      "prose-headings:font-display prose-headings:font-medium prose-headings:tracking-tight",
      "prose-a:underline-offset-[3px] prose-a:decoration-(--color-accent-600)/30 hover:prose-a:decoration-(--color-accent-600)",
      "dark:prose-a:decoration-(--color-accent-400-dark)/30 dark:hover:prose-a:decoration-(--color-accent-400-dark)",
      "prose-code:rounded prose-code:bg-(--color-paper-soft) prose-code:px-1 prose-code:py-0.5 prose-code:font-normal prose-code:text-(--color-ink)",
      "dark:prose-code:bg-(--color-paper-dark-2) dark:prose-code:text-(--color-paper-fg-2)",
      "prose-code:before:content-none prose-code:after:content-none",
      "prose-img:rounded prose-img:my-8",
      "prose-blockquote:not-italic prose-blockquote:font-display prose-blockquote:italic",
    ]}>
      <slot />
    </div>

    {post.entry.data.tags.length > 0 && (
      <section class="mt-16 font-ui text-sm text-(--color-ink-mute) dark:text-(--color-ink-faint)">
        <span class="font-display italic text-(--color-ink-soft) dark:text-(--color-paper-fg)">Filed under:</span>
        {" "}
        {post.entry.data.tags.map((tag, i, arr) => (
          <>
            <a
              href={localizedPath(post.locale, `tags/${tagSlug(tag)}`)}
              class="underline-offset-[3px] decoration-(--color-ink-faint) hover:text-(--color-accent-600) hover:decoration-(--color-accent-600) hover:underline dark:hover:text-(--color-accent-400-dark) dark:hover:decoration-(--color-accent-400-dark)"
            >{tag}</a>
            {i < arr.length - 1 && <span>, </span>}
          </>
        ))}
      </section>
    )}

    {translations.length > 1 && (
      <section class="mt-6 font-ui text-sm text-(--color-ink-mute) dark:text-(--color-ink-faint)">
        <span class="font-display italic text-(--color-ink-soft) dark:text-(--color-paper-fg)">{meta.ui.translations}:</span>
        {" "}
        {translations
          .filter((t) => t.locale !== post.locale)
          .map((t, i, arr) => (
            <>
              <a
                href={localizedPath(t.locale, `posts/${t.slug}`)}
                lang={t.locale}
                class="underline-offset-[3px] decoration-(--color-ink-faint) hover:text-(--color-accent-600) hover:decoration-(--color-accent-600) hover:underline dark:hover:text-(--color-accent-400-dark) dark:hover:decoration-(--color-accent-400-dark)"
              >
                {getLocale(t.locale).data.languageName}
              </a>
              {i < arr.length - 1 && <span>, </span>}
            </>
          ))}
      </section>
    )}

    {(newer || older) && (
      <nav class="mt-12 grid grid-cols-2 gap-6 border-t border-double border-(--color-rule) pt-8 dark:border-(--color-rule-dark)">
        <div>
          {older && (
            <a href={localizedPath(older.locale, `posts/${older.slug}`)} class="block transition hover:text-(--color-accent-600) dark:hover:text-(--color-accent-400-dark)">
              <div class="font-ui text-[10px] uppercase tracking-[0.18em] text-(--color-ink-faint)">← {meta.ui.prev_page}</div>
              <div class="font-display mt-2 line-clamp-2 italic text-(--color-ink-soft) dark:text-(--color-paper-fg)">
                {older.entry.data.title}
              </div>
            </a>
          )}
        </div>
        <div class="text-right">
          {newer && (
            <a href={localizedPath(newer.locale, `posts/${newer.slug}`)} class="block transition hover:text-(--color-accent-600) dark:hover:text-(--color-accent-400-dark)">
              <div class="font-ui text-[10px] uppercase tracking-[0.18em] text-(--color-ink-faint)">{meta.ui.next_page} →</div>
              <div class="font-display mt-2 line-clamp-2 italic text-(--color-ink-soft) dark:text-(--color-paper-fg)">
                {newer.entry.data.title}
              </div>
            </a>
          )}
        </div>
      </nav>
    )}

    <Giscus locale={post.locale} />
  </article>
</BaseLayout>
