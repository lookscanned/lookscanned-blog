---
import TagPage from "../../../../components/TagPage.astro";
import { getAllTagsByLocale } from "../../../../lib/posts";
import { LOCALES, DEFAULT_LOCALE } from "../../../../i18n";

export async function getStaticPaths() {
  const out = [];
  for (const l of LOCALES) {
    if (l.code === DEFAULT_LOCALE) continue;
    const buckets = await getAllTagsByLocale(l.code);
    for (const b of buckets) {
      out.push({
        params: { locale: l.code, tag: b.slug },
        props: { locale: l.code, tag: b.name, posts: b.posts },
      });
    }
  }
  return out;
}

const { locale, tag, posts } = Astro.props;
---

<TagPage locale={locale} tag={tag} posts={posts} />
