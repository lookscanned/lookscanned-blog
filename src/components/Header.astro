---
import { getLocale, localizedPath } from "../i18n";
import LangDropdown from "./LangDropdown.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  locale: string;
  localeUrls: Record<string, string>;
  currentPath?: string;
}

const { locale, localeUrls, currentPath = "/" } = Astro.props;
const meta = getLocale(locale);
const homeUrl = localizedPath(locale, "");

const menu = meta.data.menu
  .slice()
  .sort((a, b) => (a.weight ?? Infinity) - (b.weight ?? Infinity));

function resolveUrl(url: string): string {
  if (/^https?:\/\//.test(url)) return url;
  return localizedPath(locale, url);
}
function isExternal(url: string): boolean {
  return /^https?:\/\//.test(url);
}
function isActive(url: string): boolean {
  if (isExternal(url)) return false;
  return currentPath === resolveUrl(url);
}
---

<header class="border-b border-zinc-200/70 dark:border-zinc-800/80">
  <nav class="mx-auto flex max-w-3xl items-center justify-between gap-6 px-6 py-5">
    <a
      href={homeUrl}
      class="font-display text-lg font-medium tracking-tight text-zinc-900 transition hover:text-accent-600 dark:text-zinc-50 dark:hover:text-accent-400"
      aria-label={meta.data.title}
    >
      {meta.data.title}
    </a>
    <div class="font-ui flex items-center gap-1 sm:gap-3">
      <ul class="hidden items-center gap-5 text-sm text-zinc-600 dark:text-zinc-400 sm:flex">
        {menu.map((item) => {
          const active = isActive(item.url);
          return (
            <li>
              <a
                href={resolveUrl(item.url)}
                class:list={[
                  "transition",
                  active
                    ? "text-zinc-900 dark:text-zinc-100"
                    : "hover:text-zinc-900 dark:hover:text-zinc-100",
                ]}
                aria-current={active ? "page" : undefined}
                {...isExternal(item.url) ? { target: "_blank", rel: "noopener noreferrer" } : {}}
              >
                {item.name}
                {isExternal(item.url) && (
                  <svg
                    class="-mt-0.5 ml-0.5 inline h-3 w-3 opacity-60"
                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <path d="M15 3h6v6"></path>
                    <path d="M10 14L21 3"></path>
                  </svg>
                )}
              </a>
            </li>
          );
        })}
      </ul>
      <button
        id="mobile-menu-toggle"
        type="button"
        class="flex h-8 w-8 items-center justify-center rounded text-zinc-600 transition hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100 sm:hidden"
        aria-label="Menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <LangDropdown locale={locale} localeUrls={localeUrls} />
      <ThemeToggle />
    </div>
  </nav>
  <div
    id="mobile-menu"
    class="font-ui hidden border-t border-zinc-200/70 px-6 py-3 text-sm dark:border-zinc-800/80 sm:hidden"
  >
    <ul class="flex flex-col gap-2 text-zinc-700 dark:text-zinc-300">
      {menu.map((item) => (
        <li>
          <a
            href={resolveUrl(item.url)}
            class="block py-1 transition hover:text-accent-600 dark:hover:text-accent-400"
            {...isExternal(item.url) ? { target: "_blank", rel: "noopener noreferrer" } : {}}
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const wasHidden = menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", wasHidden ? "false" : "true");
    });
  }
</script>
