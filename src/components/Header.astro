---
import { getLocale, localizedPath } from "../i18n";
import LangDropdown from "./LangDropdown.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  locale: string;
  localeUrls: Record<string, string>;
  currentPath?: string;
}

const { locale, localeUrls, currentPath = "/" } = Astro.props;
const meta = getLocale(locale);
const homeUrl = localizedPath(locale, "");

const sortedMenu = meta.data.menu
  .slice()
  .sort((a, b) => (a.weight ?? Infinity) - (b.weight ?? Infinity));

function isExternal(url: string): boolean {
  return /^https?:\/\//.test(url);
}
function resolveUrl(url: string): string {
  if (isExternal(url)) return url;
  return localizedPath(locale, url);
}

// Partition the menu into the three roles the navbar uses. Archive / Tags
// drop to the footer; Search becomes an icon; the external item becomes
// the "Try Look Scanned" CTA.
const archivedInFooter = new Set(["archives", "tags"]);
const searchEntry = sortedMenu.find((m) => m.url === "search");
const externalCta = sortedMenu.find((m) => isExternal(m.url));
const inlineMenu = sortedMenu.filter(
  (m) =>
    !archivedInFooter.has(m.url) && m.url !== "search" && !isExternal(m.url),
);

const searchUrl = searchEntry ? resolveUrl(searchEntry.url) : localizedPath(locale, "search");
const searchLabel = searchEntry?.name ?? "Search";
const searchActive = currentPath === searchUrl;
---

<header class="sticky top-0 z-50 border-b border-zinc-200/60 bg-white/80 backdrop-blur-md dark:border-zinc-800/60 dark:bg-zinc-950/80">
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between gap-4 px-6">
    <a
      href={homeUrl}
      class="text-base font-medium tracking-tight text-zinc-900 underline-offset-[3px] transition hover:underline dark:text-zinc-50"
      aria-label={meta.data.title}
    >
      {meta.data.title}
    </a>
    <div class="flex items-center gap-1 sm:gap-2">
      {inlineMenu.length > 0 && (
        <ul class="hidden items-center gap-5 pr-2 text-sm text-zinc-600 dark:text-zinc-400 sm:flex">
          {inlineMenu.map((item) => {
            const url = resolveUrl(item.url);
            const active = currentPath === url;
            return (
              <li>
                <a
                  href={url}
                  class:list={[
                    "underline-offset-[3px] transition",
                    active
                      ? "text-zinc-900 dark:text-zinc-100"
                      : "hover:text-zinc-900 hover:underline dark:hover:text-zinc-100",
                  ]}
                  aria-current={active ? "page" : undefined}
                >
                  {item.name}
                </a>
              </li>
            );
          })}
        </ul>
      )}
      <a
        href={searchUrl}
        class:list={[
          "flex h-8 w-8 items-center justify-center rounded transition",
          searchActive
            ? "bg-zinc-100 text-zinc-900 dark:bg-zinc-800 dark:text-zinc-100"
            : "text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100",
        ]}
        aria-label={searchLabel}
        title={searchLabel}
        aria-current={searchActive ? "page" : undefined}
      >
        <svg
          class="h-[18px] w-[18px]"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>
      <LangDropdown locale={locale} localeUrls={localeUrls} />
      <ThemeToggle />
      {externalCta && (
        <a
          href={externalCta.url}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 inline-flex h-8 items-center justify-center rounded-md bg-zinc-900 px-3 text-sm font-medium text-white shadow-xs transition hover:bg-zinc-700 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300 sm:ml-2"
        >
          Try {externalCta.name}
        </a>
      )}
    </div>
  </nav>
</header>
