---
import { listLocales, getLocale } from "../i18n";

interface Props {
  locale: string;
  localeUrls: Record<string, string>;
}

const { locale, localeUrls } = Astro.props;
const meta = getLocale(locale);
const allLocales = listLocales();
---

<details class="lang-dropdown relative">
  <summary
    class="flex h-8 w-8 cursor-pointer list-none items-center justify-center rounded text-(--color-ink-mute) transition hover:bg-(--color-paper-soft) hover:text-(--color-ink) dark:text-(--color-ink-faint) dark:hover:bg-(--color-paper-dark-2) dark:hover:text-(--color-paper-fg-2) [&::-webkit-details-marker]:hidden"
    aria-label={meta.ui.translations || "Translations"}
    title={meta.ui.translations || "Translations"}
  >
    <svg class="h-[18px] w-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" aria-hidden="true">
      <path d="M478.33 433.6l-90-218a22 22 0 0 0-40.67 0l-90 218a22 22 0 1 0 40.67 16.79L316.66 406h102.67l18.33 44.39A22 22 0 0 0 458 464a22 22 0 0 0 20.32-30.4zM334.83 362L368 281.65L401.17 362z" fill="currentColor"></path>
      <path d="M267.84 342.92a22 22 0 0 0-4.89-30.7c-.2-.15-15-11.13-36.49-34.73c39.65-53.68 62.11-114.75 71.27-143.49H330a22 22 0 0 0 0-44H214V70a22 22 0 0 0-44 0v20H54a22 22 0 0 0 0 44h197.25c-9.52 26.95-27.05 69.5-53.79 108.36c-31.41-41.68-43.08-68.65-43.17-68.87a22 22 0 0 0-40.58 17c.58 1.38 14.55 34.23 52.86 83.93c.92 1.19 1.83 2.35 2.74 3.51c-39.24 44.35-77.74 71.86-93.85 80.74a22 22 0 1 0 21.07 38.63c2.16-1.18 48.6-26.89 101.63-85.59c22.52 24.08 38 35.44 38.93 36.1a22 22 0 0 0 30.75-4.9z" fill="currentColor"></path>
    </svg>
  </summary>
  <div
    class="absolute right-0 z-20 mt-2 max-h-80 w-48 overflow-y-auto rounded border border-(--color-rule) bg-(--color-paper) py-1 text-sm shadow-lg dark:border-(--color-rule-dark) dark:bg-(--color-paper-dark-2)"
  >
    {allLocales.map((l) => (
      <a
        href={localeUrls[l.code]}
        lang={l.hreflang}
        dir={l.dir}
        class:list={[
          "font-ui block px-3 py-1.5 transition",
          l.code === locale
            ? "bg-(--color-paper-soft) text-(--color-ink) dark:bg-(--color-paper-dark) dark:text-(--color-paper-fg-2)"
            : "text-(--color-ink-mute) hover:bg-(--color-paper-soft) hover:text-(--color-ink) dark:text-(--color-ink-faint) dark:hover:bg-(--color-paper-dark) dark:hover:text-(--color-paper-fg-2)",
        ]}
        aria-current={l.code === locale ? "page" : undefined}
      >
        {l.data.languageName}
      </a>
    ))}
  </div>
</details>

<script>
  document.addEventListener("click", (event) => {
    document.querySelectorAll<HTMLDetailsElement>("details.lang-dropdown[open]").forEach((d) => {
      if (!d.contains(event.target as Node)) d.open = false;
    });
  });
</script>
