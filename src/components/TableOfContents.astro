---
import { getLocale } from "../i18n";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  locale: string;
}

const { headings, locale } = Astro.props;
const meta = getLocale(locale);
// Skip the page's H1; surface H2/H3 only — deeper nesting tends to
// clutter the sidebar without aiding navigation.
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{items.length > 0 && (
  <nav aria-label={meta.ui.toc} class="text-sm">
    <p class="mb-3 font-medium text-zinc-900 dark:text-zinc-100">{meta.ui.toc}</p>
    <ul class="space-y-2 border-l border-zinc-200 dark:border-zinc-800">
      {items.map((h) => (
        <li class={h.depth === 3 ? "pl-8" : "pl-4"}>
          <a
            href={`#${h.slug}`}
            data-toc-link={h.slug}
            class="block text-zinc-500 transition hover:text-zinc-900 data-[active]:font-medium data-[active]:text-zinc-900 dark:text-zinc-500 dark:hover:text-zinc-100 dark:data-[active]:text-zinc-100"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");
  if (links.length > 0) {
    const targets = [...links]
      .map((link) => document.getElementById(link.dataset.tocLink ?? ""))
      .filter((el): el is HTMLElement => el !== null);

    if (targets.length > 0) {
      let activeId: string | null = null;
      const setActive = (id: string) => {
        if (id === activeId) return;
        activeId = id;
        links.forEach((link) => {
          link.toggleAttribute("data-active", link.dataset.tocLink === id);
        });
      };
      const observer = new IntersectionObserver(
        (entries) => {
          // Multiple headings can share the activation band at boundaries;
          // pick the topmost intersecting one deterministically rather than
          // letting IO entry order decide.
          const candidates = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (candidates.length === 0) return;
          setActive(candidates[0].target.id);
        },
        { rootMargin: "-80px 0px -70% 0px" },
      );
      targets.forEach((t) => observer.observe(t));
    }
  }
</script>
