---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPostsByLocale } from "../lib/posts";

const posts = await getPostsByLocale("en");
---

<BaseLayout title="Look Scanned Blog" locale="en">
  <main class="mx-auto max-w-2xl px-6 py-16">
    <h1 class="text-3xl font-medium tracking-tight">Look Scanned Blog</h1>
    <p class="mt-3 text-zinc-600 dark:text-zinc-400">
      Phase 2 smoke test — {posts.length} English posts loaded from the collection.
    </p>
    <ul class="mt-8 space-y-3">
      {posts.slice(0, 5).map((p) => (
        <li class="text-sm">
          <span class="text-zinc-500">{p.entry.data.date.toISOString().slice(0, 10)}</span>
          <span class="ml-3">{p.entry.data.title}</span>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>
