---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "./PostList.astro";
import Pagination from "./Pagination.astro";
import { getLocale } from "../i18n";
import { getPostsByLocale } from "../lib/posts";
import { paginateItems, PAGE_SIZE } from "../lib/paginate";
import { renderInlineMarkdown } from "../lib/markdown";

interface Props {
  locale: string;
  page?: number;
}

const { locale, page = 1 } = Astro.props;
const meta = getLocale(locale);
const all = await getPostsByLocale(locale);
const pages = paginateItems(all, PAGE_SIZE);
const current = pages[Math.max(0, Math.min(page - 1, pages.length - 1))];

const title = page > 1
  ? `${meta.data.title} · ${page}/${current.total}`
  : meta.data.title;
---

<BaseLayout title={title} description={meta.data.description} locale={locale}>
  <main class="mx-auto max-w-3xl px-6 py-12">
    {page === 1 && (
      <section class="border-b border-zinc-200/70 pb-10 dark:border-zinc-800/80">
        <h1 class="text-2xl font-medium tracking-tight text-zinc-950 dark:text-zinc-50">{meta.data.homeTitle}</h1>
        <div
          class="mt-4 prose prose-zinc max-w-none dark:prose-invert [--tw-prose-body:var(--color-zinc-800)] dark:[--tw-prose-body:var(--color-zinc-200)] prose-a:text-accent-600 prose-a:no-underline hover:prose-a:underline dark:prose-a:text-accent-500 prose-p:my-2 prose-ul:my-2"
          set:html={renderInlineMarkdown(meta.data.homeContent)}
        />
      </section>
    )}
    <div class={page === 1 ? "mt-8" : "mt-2"}>
      <PostList posts={current.items} />
    </div>
    <Pagination locale={locale} current={current.page} total={current.total} basePath="" />
  </main>
</BaseLayout>
