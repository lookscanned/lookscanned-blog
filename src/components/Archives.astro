---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocale, localizedPath } from "../i18n";
import { getPostsByLocale } from "../lib/posts";
import { formatDayMonth } from "../lib/date";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const meta = getLocale(locale);
const posts = await getPostsByLocale(locale);

const archiveMenu = meta.data.menu.find((m) => m.url === "archives");
const archiveTitle = archiveMenu?.name ?? "Archive";

const grouped = new Map<number, typeof posts>();
for (const p of posts) {
  const year = p.entry.data.date.getFullYear();
  const list = grouped.get(year) ?? [];
  list.push(p);
  grouped.set(year, list);
}
const years = [...grouped.keys()].sort((a, b) => b - a);
---

<BaseLayout title={`${archiveTitle} · ${meta.data.title}`} description={meta.data.description} locale={locale} pageKey="archives">
  <main class="mx-auto max-w-5xl px-6 pt-12 pb-12 sm:pt-16">
    <h1 class="text-3xl font-medium leading-tight tracking-tight text-zinc-900 sm:text-4xl dark:text-zinc-50">
      {archiveTitle}
    </h1>
    <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-400">
      {posts.length} posts
    </p>

    <div class="mt-12 space-y-12">
      {years.map((year) => (
        <section>
          <h2 class="text-sm font-medium tabular-nums tracking-wider text-zinc-400 dark:text-zinc-600">{year}</h2>
          <ul class="mt-4 divide-y divide-zinc-200 dark:divide-zinc-800">
            {grouped.get(year)!.map((p) => (
              <li>
                <a
                  href={localizedPath(locale, `posts/${p.slug}`)}
                  class="group grid grid-cols-[5rem_1fr] items-baseline gap-x-6 py-3 sm:grid-cols-[7rem_1fr] sm:gap-x-8"
                >
                  <span class="text-xs tabular-nums uppercase tracking-wider text-zinc-400 dark:text-zinc-600">
                    {formatDayMonth(locale, p.entry.data.date)}
                  </span>
                  <span class="text-base text-zinc-800 underline-offset-[3px] group-hover:underline dark:text-zinc-200 sm:text-lg">
                    {p.entry.data.title}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>
