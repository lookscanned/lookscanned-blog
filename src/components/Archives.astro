---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocale, localizedPath } from "../i18n";
import { getPostsByLocale } from "../lib/posts";
import { formatDayMonth } from "../lib/date";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const meta = getLocale(locale);
const posts = await getPostsByLocale(locale);

const archiveMenu = meta.data.menu.find((m) => m.url === "archives");
const archiveTitle = archiveMenu?.name ?? "Archive";

const grouped = new Map<number, typeof posts>();
for (const p of posts) {
  const year = p.entry.data.date.getFullYear();
  const list = grouped.get(year) ?? [];
  list.push(p);
  grouped.set(year, list);
}
const years = [...grouped.keys()].sort((a, b) => b - a);
---

<BaseLayout title={`${archiveTitle} · ${meta.data.title}`} description={meta.data.description} locale={locale} pageKey="archives">
  <main class="mx-auto max-w-3xl px-6 pt-10 pb-12 sm:pt-16">
    <p class="font-ui text-[11px] uppercase tracking-[0.18em] text-(--color-ink-faint)">
      The complete index · {posts.length} {posts.length === 1 ? "entry" : "entries"}
    </p>
    <h1 class="font-display mt-4 text-[2.75rem] font-medium italic leading-[1.05] tracking-tight text-(--color-ink) sm:text-[3.5rem] dark:text-(--color-paper-fg-2)">
      {archiveTitle}
    </h1>

    <div class="mt-10 space-y-12">
      {years.map((year) => (
        <section>
          <h2 class="font-mono text-sm tabular-nums tracking-[0.1em] text-(--color-ink-faint)">{year}</h2>
          <ul class="mt-4 divide-y divide-(--color-rule) dark:divide-(--color-rule-dark)">
            {grouped.get(year)!.map((p) => (
              <li>
                <a
                  href={localizedPath(locale, `posts/${p.slug}`)}
                  class="group grid grid-cols-[5rem_1fr] items-baseline gap-x-6 py-3 transition sm:grid-cols-[7rem_1fr] sm:gap-x-8"
                >
                  <span class="font-mono text-xs tabular-nums uppercase tracking-[0.1em] text-(--color-ink-faint) transition group-hover:text-(--color-accent-600) dark:group-hover:text-(--color-accent-400-dark)">
                    {formatDayMonth(locale, p.entry.data.date)}
                  </span>
                  <span class="font-display text-base text-(--color-ink-soft) transition group-hover:text-(--color-accent-700) dark:text-(--color-paper-fg) dark:group-hover:text-(--color-accent-300-dark) sm:text-lg">
                    {p.entry.data.title}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>
