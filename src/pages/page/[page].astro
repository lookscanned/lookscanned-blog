---
import Home from "../../components/Home.astro";
import { getPostsByLocale } from "../../lib/posts";
import { paginateItems, PAGE_SIZE } from "../../lib/paginate";

export async function getStaticPaths() {
  const all = await getPostsByLocale("en");
  const pages = paginateItems(all, PAGE_SIZE);
  return pages.map((p) => ({
    params: { page: String(p.page) },
    props: { page: p.page },
  }));
}

const { page } = Astro.props;
---

<Home locale="en" page={page} />
