---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocale } from "../i18n";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const meta = getLocale(locale);
---

<BaseLayout title={`Categories · ${meta.data.title}`} description={meta.data.description} locale={locale} pageKey="categories">
  <main class="mx-auto max-w-5xl px-6 pt-12 pb-12 sm:pt-16">
    <h1 class="text-3xl font-medium leading-tight tracking-tight text-zinc-900 sm:text-4xl dark:text-zinc-50">
      Categories
    </h1>
    <p class="mt-6 text-sm text-zinc-600 dark:text-zinc-400">
      No categories yet. Browse <a href="/tags/" class="text-accent-600 underline-offset-[3px] hover:underline dark:text-accent-400">tags</a> instead.
    </p>
  </main>
</BaseLayout>
