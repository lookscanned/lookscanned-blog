---
import { getLocale } from "../i18n";

interface Props {
  locale: string;
  current: number;
  total: number;
  /** Path prefix without trailing slash, e.g. "" for home, "/posts" for section. */
  basePath: string;
}

const { locale, current, total, basePath } = Astro.props;
if (total <= 1) return null;

const meta = getLocale(locale);
const localeRoot = locale === "en" ? "" : `/${locale}`;
const indexUrl = `${localeRoot}${basePath}/`.replace(/^\/\//, "/");

function url(page: number): string {
  if (page === 1) {
    if (basePath === "") return localeRoot ? `${localeRoot}/` : "/";
    return indexUrl;
  }
  return `${localeRoot}${basePath}/page/${page}/`;
}

const prev = current > 1 ? url(current - 1) : null;
const next = current < total ? url(current + 1) : null;
---

<nav
  class="mt-16 flex items-center justify-between border-t border-zinc-200 pt-6 text-sm dark:border-zinc-800"
  aria-label="Pagination"
>
  {prev ? (
    <a
      href={prev}
      rel="prev"
      class="text-zinc-600 transition hover:text-accent-600 dark:text-zinc-400 dark:hover:text-accent-400"
    >
      ← {meta.ui.prev_page}
    </a>
  ) : (
    <span class="text-zinc-300 dark:text-zinc-700">← {meta.ui.prev_page}</span>
  )}
  <span class="tabular-nums text-zinc-500 dark:text-zinc-400">
    {current} / {total}
  </span>
  {next ? (
    <a
      href={next}
      rel="next"
      class="text-zinc-600 transition hover:text-accent-600 dark:text-zinc-400 dark:hover:text-accent-400"
    >
      {meta.ui.next_page} →
    </a>
  ) : (
    <span class="text-zinc-300 dark:text-zinc-700">{meta.ui.next_page} →</span>
  )}
</nav>
