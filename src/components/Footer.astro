---
import { getLocale } from "../i18n";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const meta = getLocale(locale);
const year = new Date().getFullYear();
const rssUrl = locale === "en" ? "/rss.xml" : `/${locale}/rss.xml`;
---

<footer class="mt-20 border-t border-zinc-200/60 dark:border-zinc-800/60">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-6 py-8 text-sm text-zinc-500 dark:text-zinc-400">
    <span>&copy; {year} {meta.data.title}</span>
    <div class="flex items-center gap-4">
      <a
        href="https://lookscanned.io"
        class="underline-offset-[3px] transition hover:underline"
        target="_blank" rel="noopener noreferrer"
      >Look Scanned</a>
      <a
        href="https://github.com/lookscanned"
        class="underline-offset-[3px] transition hover:underline"
        target="_blank" rel="noopener noreferrer"
      >GitHub</a>
      <a
        href={rssUrl}
        class="underline-offset-[3px] transition hover:underline"
      >RSS</a>
    </div>
  </div>
</footer>
