---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocale } from "../i18n";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const meta = getLocale(locale);
---

<BaseLayout title={`Categories · ${meta.data.title}`} description={meta.data.description} locale={locale} pageKey="categories">
  <main class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="text-2xl font-medium tracking-tight text-zinc-950 dark:text-zinc-50">Categories</h1>
    <p class="mt-4 text-sm text-zinc-500 dark:text-zinc-400">
      No categories yet.
    </p>
  </main>
</BaseLayout>
