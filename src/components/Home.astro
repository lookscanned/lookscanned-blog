---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "./PostList.astro";
import Pagination from "./Pagination.astro";
import { getLocale } from "../i18n";
import { getPostsByLocale } from "../lib/posts";
import { paginateItems, PAGE_SIZE } from "../lib/paginate";

interface Props {
  locale: string;
  page?: number;
}

const { locale, page = 1 } = Astro.props;
const meta = getLocale(locale);
const all = await getPostsByLocale(locale);
const pages = paginateItems(all, PAGE_SIZE);
const current = pages[Math.max(0, Math.min(page - 1, pages.length - 1))];

const title = page > 1
  ? `${meta.data.title} · ${page}/${current.total}`
  : meta.data.title;
---

<BaseLayout title={title} description={meta.data.description} locale={locale}>
  <main class="mx-auto max-w-3xl px-6">
    {page === 1 && (
      <section class="pt-12 pb-10 sm:pt-16">
        <h1 class="font-display text-4xl font-medium leading-[1.1] tracking-tight text-balance text-zinc-900 sm:text-5xl dark:text-zinc-50">
          {meta.data.homeTitle}
        </h1>
        <p class="font-ui mt-6 max-w-xl text-[15px] leading-relaxed text-zinc-600 dark:text-zinc-400">
          {meta.data.description}
        </p>
      </section>
    )}
    {page > 1 && (
      <section class="pt-12 pb-8 sm:pt-16">
        <p class="font-ui text-sm text-zinc-500 dark:text-zinc-400">
          Page {page} of {current.total}
        </p>
      </section>
    )}
    <div class="border-t border-zinc-200 dark:border-zinc-800">
      <PostList posts={current.items} />
    </div>
    <Pagination locale={locale} current={current.page} total={current.total} basePath="" />
  </main>
</BaseLayout>
