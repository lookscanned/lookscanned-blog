---
import { getLocale, localizedPath } from "../i18n";
import LangDropdown from "./LangDropdown.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const meta = getLocale(locale);
const homeUrl = localizedPath(locale, "");

const menu = meta.data.menu
  .slice()
  .sort((a, b) => (a.weight ?? Infinity) - (b.weight ?? Infinity));

function resolveUrl(url: string): string {
  if (/^https?:\/\//.test(url)) return url;
  return localizedPath(locale, url);
}

function isExternal(url: string): boolean {
  return /^https?:\/\//.test(url);
}
---

<header class="border-b border-zinc-200/70 dark:border-zinc-800/80">
  <nav class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-6 py-5">
    <a
      href={homeUrl}
      class="text-base font-medium tracking-tight text-zinc-900 hover:text-accent-600 dark:text-zinc-100 dark:hover:text-accent-500"
      aria-label={meta.data.title}
    >
      {meta.data.title}
    </a>
    <div class="flex items-center gap-1 sm:gap-3">
      <ul class="hidden items-center gap-4 text-sm text-zinc-600 dark:text-zinc-400 sm:flex">
        {menu.map((item) => (
          <li>
            <a
              href={resolveUrl(item.url)}
              class="transition hover:text-zinc-900 dark:hover:text-zinc-100"
              {...isExternal(item.url) ? { target: "_blank", rel: "noopener" } : {}}
            >
              {item.name}
              {isExternal(item.url) && (
                <svg
                  class="-mt-0.5 ml-0.5 inline h-3 w-3 text-zinc-400"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <path d="M15 3h6v6"></path>
                  <path d="M10 14L21 3"></path>
                </svg>
              )}
            </a>
          </li>
        ))}
      </ul>
      <LangDropdown locale={locale} />
      <ThemeToggle />
    </div>
  </nav>
</header>
