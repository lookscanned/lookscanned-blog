---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "./PostCard.astro";
import { getLocale } from "../i18n";
import type { PostMeta } from "../lib/posts";

interface Props {
  locale: string;
  tag: string;
  posts: PostMeta[];
}

const { locale, tag, posts } = Astro.props;
const meta = getLocale(locale);
const menuEntry = meta.data.menu.find((m) => m.url === "tags");
const tagsLabel = menuEntry?.name ?? "Tags";
const title = `${tag} · ${tagsLabel} · ${meta.data.title}`;
---

<BaseLayout title={title} description={meta.data.description} locale={locale}>
  <main class="mx-auto max-w-2xl px-6 py-12">
    <p class="text-xs uppercase tracking-wide text-zinc-500">{tagsLabel}</p>
    <h1 class="mt-1 text-2xl font-medium tracking-tight">{tag}</h1>
    <section class="mt-8 divide-y divide-zinc-200/70 dark:divide-zinc-800/80">
      {posts.map((post) => <PostCard post={post} />)}
    </section>
  </main>
</BaseLayout>
