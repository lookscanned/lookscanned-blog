---
import { formatReadingTime, localizedPath } from "../i18n";
import readingTime from "reading-time";

interface Props {
  locale: string;
  date: Date;
  tags: string[];
  body: string;
}

const { locale, date, tags, body } = Astro.props;
const rt = readingTime(body);
const minutes = Math.max(1, Math.round(rt.minutes));
const readTimeStr = formatReadingTime(locale, minutes);
const dateStr = date.toISOString().slice(0, 10);
---

<div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-zinc-500 dark:text-zinc-400">
  <time datetime={date.toISOString()}>{dateStr}</time>
  <span aria-hidden="true">·</span>
  <span>{readTimeStr}</span>
  {tags.length > 0 && (
    <>
      <span aria-hidden="true">·</span>
      <ul class="flex flex-wrap gap-x-2 gap-y-1">
        {tags.map((tag) => (
          <li>
            <a
              href={localizedPath(locale, `tags/${tag.toLowerCase().replace(/\s+/g, "-")}`)}
              class="rounded px-1.5 py-0.5 text-xs text-zinc-500 ring-1 ring-zinc-200 transition hover:text-zinc-900 hover:ring-zinc-300 dark:text-zinc-400 dark:ring-zinc-800 dark:hover:text-zinc-100 dark:hover:ring-zinc-700"
            >
              {tag}
            </a>
          </li>
        ))}
      </ul>
    </>
  )}
</div>
